# ============================================================
# Spinrise ERP — .gitignore
# ============================================================

# ------------------------------------------------------------
# .NET — build outputs
# ------------------------------------------------------------
**/bin/
**/obj/
**/artifacts/
**/*.pdb
**/*.publish.xml

# ------------------------------------------------------------
# .NET — generated / user-specific
# ------------------------------------------------------------
**/*.user
**/*.suo
**/*.sln.docstates
**/*.vspscc
**/*.vssscc
**/launchSettings.json

# ------------------------------------------------------------
# Visual Studio IDE
# ------------------------------------------------------------
.vs/
**/. vs/
**/.vs/

# ------------------------------------------------------------
# ASP.NET — environment-specific config (keep appsettings.json)
# ------------------------------------------------------------
**/appsettings.Development.json
**/appsettings.Production.json
**/appsettings.Staging.json
**/appsettings.local.json

# ------------------------------------------------------------
# Node / Frontend (Development/spinrise-web)
# ------------------------------------------------------------
**/node_modules/
**/dist/
**/build/
**/.vite/
**/.cache/

# Frontend env files (all environments)
Development/spinrise-web/.env
Development/spinrise-web/.env.*
!Development/spinrise-web/.env.example

# Frontend debug logs
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# Vite / TypeScript cache
**/tsconfig.tsbuildinfo

# ------------------------------------------------------------
# Database scripts — generated merge file
# ------------------------------------------------------------
Development/Backend/Spinrise.DBScripts/merged.sql

# ------------------------------------------------------------
# Claude Code — local (machine-specific) settings only
# ------------------------------------------------------------
.claude/settings.local.json

# Claude session memory stored at repo root (personal, not shared)
memory/

# ------------------------------------------------------------
# Temporary / scratch files at repo root
# ------------------------------------------------------------
error.txt
prompt.txt
prompt2.txt
prompt.md
prompts/

# ------------------------------------------------------------
# OS artefacts
# ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ------------------------------------------------------------
# JetBrains IDEs
# ------------------------------------------------------------
.idea/
*.iml

# ------------------------------------------------------------
# Test results / coverage
# ------------------------------------------------------------
**/TestResults/
**/coverage/
**/.nyc_output/
lcov.info
**/*.lcov

# ------------------------------------------------------------
# Publish profiles (machine-specific)
# ------------------------------------------------------------
**/Properties/PublishProfiles/
**/*.pubxml
**/*.pubxml.user
